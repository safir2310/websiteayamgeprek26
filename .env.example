# Database - PostgreSQL (Neon)
# Recommended for most uses
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# For uses requiring a connection without pgbouncer
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/database?sslmode=require"

# Environment
NODE_ENV="production"

# WebSocket (Optional - for development only)
# In production, use a separate WebSocket service
# WEBSOCKET_URL="http://localhost:3003"

# NextAuth (Optional - if needed in future)
# NEXTAUTH_URL="https://your-domain.com"
# NEXTAUTH_SECRET="your-secret-key"

# Custom Configuration
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
